{
  "expo": {
    "name": "HexWalk",
    "slug": "hexwalk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hexwalk",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ranuk.hexwalk",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "HexWalk necesita acceder a tu ubicación para registrar los hexágonos que desbloqueas al caminar.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "HexWalk necesita acceder a tu ubicación en segundo plano para continuar registrando tus caminatas y desbloqueando el mapa.",
        "NSLocationAlwaysUsageDescription": "HexWalk necesita acceder a tu ubicación en segundo plano para registrar tus caminatas y desbloqueando el mapa.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "package": "com.ranuk.hexwalk",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#121214",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#121214",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
